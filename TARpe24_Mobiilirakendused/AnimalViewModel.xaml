<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TARpe24_Mobiilirakendused.AnimalViewModel"
             Title="AnimalViewModel">
    <VerticalStackLayout Spacing="20" Padding="30" HorizontalOptions="Center">

        <Image Source="{Binding CurrentAnimalImage}"
               HeightRequest="200"
               WidthRequest="200" />

        <Button Text="Näita Koera" 
                Clicked="OnDogClicked" />
        <Button Text="Näita Kala" 
                Clicked="OnFishClicked" />

    </VerticalStackLayout>
</ContentPage>