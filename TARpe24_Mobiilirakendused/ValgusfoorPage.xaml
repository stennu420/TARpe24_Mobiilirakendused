<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TARpe24_Mobiilirakendused.ValgusfoorPage"
             Title="ValgusfoorPage">
    <VerticalStackLayout Padding="30" Spacing="20">


        <!-- Pealkiri -->
        <Label x:Name="StatusLabel"
               Text="Vali valgus"
               FontSize="24"
               HorizontalOptions="Center"
               FontAttributes="Bold" />

        <!-- Punane -->
        <Frame x:Name="RedLight"
               HeightRequest="120"
               WidthRequest="120"
               CornerRadius="60"
               BackgroundColor="Gray"
               HorizontalOptions="Center">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnRedTapped"/>
            </Frame.GestureRecognizers>
            <Label Text="punane" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Frame>

        <!-- Kollane -->
        <Frame x:Name="YellowLight"
               HeightRequest="120"
               WidthRequest="120"
               CornerRadius="60"
               BackgroundColor="Gray"
               HorizontalOptions="Center">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnYellowTapped"/>
            </Frame.GestureRecognizers>
            <Label Text="kollane" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Frame>

        <!-- Roheline -->
        <Frame x:Name="GreenLight"
               HeightRequest="120"
               WidthRequest="120"
               CornerRadius="60"
               BackgroundColor="Gray"
               HorizontalOptions="Center">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnGreenTapped"/>
            </Frame.GestureRecognizers>
            <Label Text="roheline" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Frame>

        <!-- Nupud -->
        <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
            <Button Text="SISSE" Clicked="OnSisseClicked"/>
            <Button Text="VÄLJA" Grid.Column="1" Clicked="OnValjaClicked"/>
        </Grid>

    </VerticalStackLayout>
</ContentPage>